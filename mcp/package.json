{
  "name": "@yshi/mcp-server",
  "version": "1.0.0",
  "description": "Model Context Protocol (MCP) server for Yshi integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node dist/index.js",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "axios": "^1.7.0",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "yshi",
    "mcp",
    "model-context-protocol",
    "llm",
    "integration",
    "webhook",
    "oauth"
  ],
  "author": "Yshi Team",
  "license": "MIT"
}
